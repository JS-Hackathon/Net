# =============================================================================
# MockAI FRONTEND — environment template (Next.js)
# =============================================================================
# Copy to `.env.local` for local development:
#   cp .env.example .env.local
# On Vercel these are set in Project Settings → Environment Variables.
# =============================================================================

# Base URL of the backend API.
# IMPORTANT: do NOT include the `/api/v1` suffix — the axios client adds it.
# Including it produces doubled paths like `/api/v1/api/v1/auth/me` → 404.
#
# Local:  http://127.0.0.1:8000   (use 127.0.0.1 on Windows to avoid IPv6 latency)
# Vercel: https://net-bzr9.onrender.com
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
