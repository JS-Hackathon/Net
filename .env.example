# Database Credentials
POSTGRES_USER=root
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=my_database
# IMPORTANT (Windows/Docker): use 127.0.0.1, NOT localhost. On Windows, "localhost"
# resolves to IPv6 (::1) first while the Postgres container is published on IPv4,
# adding ~1-2s connection latency to EVERY request. 127.0.0.1 forces IPv4.
DATABASE_URL=postgresql+asyncpg://root:your_password_here@127.0.0.1:5433/my_database

# External APIs
GEMINI_API_KEY=your_gemini_api_key_here
JSEARCH_API_KEY=your_jsearch_api_key_here

# Google OAuth2 Keys
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:3000

# Security
JWT_SECRET=your_jwt_secret_here
