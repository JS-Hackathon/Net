# =============================================================================
# MockAI BACKEND — environment template
# =============================================================================
# The backend loads this file from the REPO ROOT (see app/core/config.py).
# docker-compose.yml also reads it (env_file: .env) for the Postgres container.
#   cp .env.example .env      # then fill in real values
# NEVER commit the real `.env`. On Render these are set as dashboard env vars.
# =============================================================================

# --- Runtime -----------------------------------------------------------------
# development | production. MUST be "production" on Render — otherwise debug
# mode leaks tracebacks and drops CORS headers on 500 responses.
ENV=development
# Log every SQL statement (verbose; dev only).
SQL_ECHO=false

# --- Database ----------------------------------------------------------------
# These POSTGRES_* values are consumed BOTH by the Postgres container
# (docker-compose) and by config validation — keep them in sync with DATABASE_URL.
POSTGRES_USER=root
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=my_database
# IMPORTANT (Windows/Docker): use 127.0.0.1, NOT localhost. On Windows "localhost"
# resolves to IPv6 (::1) first while the Postgres container is published on IPv4,
# adding ~1-2s connection latency to EVERY request. 127.0.0.1 forces IPv4.
# The Docker Postgres is published on host port 5433 (see docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://root:your_password_here@127.0.0.1:5433/my_database
# On Render use the EXTERNAL connection string of the Render Postgres, keeping
# the +asyncpg driver, e.g.:
#   postgresql+asyncpg://USER:PASSWORD@dpg-xxxx.oregon-postgres.render.com/DBNAME

# --- Security ----------------------------------------------------------------
# Strong random secret. MUST be identical between token issue (Google callback)
# and verify (/auth/me). Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=your_jwt_secret_here
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS --------------------------------------------------------------------
# Comma-separated, NO trailing slash. Must include the frontend origin, or the
# browser blocks /auth/me and /auth/refresh (observed CORS failures).
# Local:
ALLOWED_ORIGINS=http://localhost:3000
# Render (prod) should be:
#   http://localhost:3000,https://mock-ai-ci26.vercel.app

# --- Frontend redirect (used after Google OAuth) -----------------------------
# Local: http://localhost:3000   Render: https://mock-ai-ci26.vercel.app
FRONTEND_URL=http://localhost:3000

# --- Google OAuth2 -----------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# MUST exactly match an Authorized redirect URI in Google Cloud Console.
# Local: http://localhost:8000/api/v1/auth/google/callback
# Render: https://net-bzr9.onrender.com/api/v1/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# --- External AI / data providers --------------------------------------------
# Missing GEMINI_API_KEY  => CV parsing & job matching fall back to mock/fail.
GEMINI_API_KEY=your_gemini_api_key_here
# Missing JSEARCH_API_KEY => jobs search seeds mock data (no crash).
JSEARCH_API_KEY=your_jsearch_api_key_here
JSEARCH_COUNTRY=vn
JSEARCH_DATE_POSTED=all

# --- Cloudflare R2 (file storage: CV & avatar uploads) -----------------------
R2_BUCKET_NAME=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
